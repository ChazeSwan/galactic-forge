{% comment %}
  snippets/icon-sith-emblem.liquid
  ─────────────────────────────────────────────────────────────────────────────
  Sith lightsaber — blade pointing up, hilt at the bottom.

  The .ls-blade group uses fill="currentColor" so CSS controls the color.
  The parent .gf-panel--dark sets `color: #C53030` (Sith crimson).

  Blade animation (grow from hilt upward on hover) is handled in CSS
  by targeting the .ls-blade class with scaleY + transform-origin.

  Hilt parts use fixed neutral greys — they are always fully visible.
  ─────────────────────────────────────────────────────────────────────────────
{% endcomment %}

<svg viewBox="0 0 40 200" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">

  {% comment %} Blade — animated on hover, color set by CSS currentColor {% endcomment %}
  <g class="ls-blade">
    {% comment %} Rounded tip at the very top of the blade {% endcomment %}
    <ellipse cx="20" cy="8" rx="3" ry="5" fill="currentColor"/>
    {% comment %} Main shaft of the blade {% endcomment %}
    <rect x="17" y="8" width="6" height="112" rx="3" fill="currentColor"/>
  </g>

  {% comment %} Guard — the crosspiece where blade meets hilt {% endcomment %}
  <rect x="6" y="118" width="28" height="6" rx="2" fill="#888"/>

  {% comment %} Hilt body — the handle {% endcomment %}
  <rect x="14" y="124" width="12" height="52" rx="2" fill="#666"/>

  {% comment %} Hilt detail bands — decorative grip rings {% endcomment %}
  <rect x="12" y="135" width="16" height="2.5" rx="1" fill="#999"/>
  <rect x="12" y="148" width="16" height="2.5" rx="1" fill="#999"/>
  <rect x="12" y="161" width="16" height="2.5" rx="1" fill="#999"/>

  {% comment %} Pommel — the rounded base of the hilt {% endcomment %}
  <ellipse cx="20" cy="179" rx="9" ry="5" fill="#555"/>

</svg>
